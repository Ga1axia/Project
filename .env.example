# Database (SQLite for pilot; use postgres URL for production)
DATABASE_URL="file:./dev.db"

# Pilot auth: comma-separated list of employee IDs that can act as managers
# In production, replace with SSO/Entra and resolve from token
MANAGER_EMPLOYEE_IDS=EMP001,EMP002

# Current user override for pilot (no SSO): set to an employee ID to impersonate
# Leave empty in production when using real auth
CURRENT_USER_EMPLOYEE_ID=

# --- Ref Tab API (equipment source) ---
# Base URL of the ref tab API
REF_TAB_API_URL=https://ref-tab.example.com/api
# API key or bearer token for ref tab
REF_TAB_API_KEY=

# --- Notifications (IT alerts) ---
# One of: email | teams | webhook
NOTIFICATION_PROVIDER=webhook
# For email: SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_TO=it@company.com
# For Teams: incoming webhook URL
TEAMS_WEBHOOK_URL=
# For webhook: generic POST URL (e.g. n8n)
WEBHOOK_URL=

# Optional: base URL of this app (for links in notifications)
APP_BASE_URL=http://localhost:3000
