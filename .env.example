# Database (SQLite for pilot; use postgres URL for production)
DATABASE_URL="file:./dev.db"

# Pilot auth: comma-separated list of employee IDs that can act as managers
# In production, replace with SSO/Entra and resolve from token
MANAGER_EMPLOYEE_IDS=EMP001,EMP002

# Current user override for pilot (no SSO): set to an employee ID to impersonate
# Leave empty in production when using real auth
CURRENT_USER_EMPLOYEE_ID=

# --- Reftab (https://www.reftab.com/api-docs) — equipment / assignments source ---
# Auth is HMAC (public + secret keys from Reftab: Settings → API Keys → Create API Key).
# Signing matches Reftab’s documented flow: https://www.reftab.com/faq/postman-reftab-api
# Optional Node reference client: https://github.com/Reftab/ReftabNode
REF_TAB_API_URL=https://www.reftab.com/api
REF_TAB_API_PUBLIC_KEY=
REF_TAB_API_SECRET_KEY=
# How many assets to request per sync (1–5000). Reftab supports ?limit= on GET /assets
REF_TAB_ASSETS_LIMIT=500
# Dot-path on each asset that identifies the assignee (must match User.employeeId in this app, or your directory’s id/email)
# Examples: loanee, loanee.email, customFieldId — inspect your GET /assets JSON from api-docs or Postman
REF_TAB_ASSIGNEE_FIELD=loanee
# Dot-paths for display (defaults match common Reftab asset fields)
REF_TAB_ASSET_TAG_FIELD=id
REF_TAB_SERIAL_FIELD=serial
REF_TAB_MODEL_FIELD=title

# Legacy only: Bearer token + GET .../assignments?employee_id= for a custom API gateway (not official Reftab)
# REF_TAB_API_KEY=

# --- Notifications (IT alerts) ---
# One of: email | teams | webhook
NOTIFICATION_PROVIDER=webhook
# For email: SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_TO=it@company.com
# For Teams: incoming webhook URL
TEAMS_WEBHOOK_URL=
# For webhook: generic POST URL (e.g. n8n)
WEBHOOK_URL=

# Optional: base URL of this app (for links in notifications)
APP_BASE_URL=http://localhost:3000
